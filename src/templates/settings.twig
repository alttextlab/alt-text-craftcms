{% set selectedSubnavItem = 'Settings' %}

{% import '_includes/forms.twig' as forms %}

<style>
    .text-dunger{
        color: red;
    }

    .text-success{
        color: green;
    }
    #disabledVolumeUids-field .checkbox-select {
        display: flex;
        flex-wrap: wrap;
        gap: 6px 12px;
    }

    #disabledVolumeUids-field .checkbox-select .checkbox {
        display: inline-flex;
        align-items: center;
        margin: 0;
    }

    .alttextlab-select-locked {
        opacity: 0.65;
        cursor: not-allowed;
    }
    .alttextlab-select-locked select {
        pointer-events: none;
    }
</style>

<div id="url-settings" class="nested-fields ">
    {{ forms.textField({
        label: "AltTextLab API Key",
        id: 'apiKey',
        class: 'ltr',
        name: 'apiKey',
        value: settings.apiKey,
        errors: settings.getErrors('apiKey')
    }) }}
</div>

<div style="margin-top: 5px">
    {% if settings.apiKey and not account %}
        <p class="text-dunger">
            Your API key is invalid. Please check your API key or
            <a
                href="https://app.alttextlab.com/settings/api-keys?utm_medium=integration&utm_source=craftcms&utm_campaign=internal_use&utm_content=invalid_api_key"
                rel="noopener noreferrer"
                target="_blank"
                class="">
                    create a new API key
            </a>.
        </p>
    {% elseif settings.apiKey and account %}
        <p class="text-success">Your API key is valid. Credits on your account: <strong>{{ account.credits }}</strong>.</p>
    {% else %}
        <p>Get your API Key at <a href="https://app.alttextlab.com/settings/api-keys?utm_medium=integration&utm_source=craftcms&utm_campaign=internal_use&utm_content=api-key-hint" rel="noopener noreferrer" target="_blank">AltTextLab.com</a> > API Keys > Create API key</p>
    {% endif %}
</div>

{# Start Auto-generate alt text #}
{{ forms.lightswitchField({
    label: "Auto-generate alt text for new assets",
    instructions: "",
    id: 'onUploadGenerate',
    name: 'onUploadGenerate',
    on: settings.onUploadGenerate
}) }}
{# End Auto-generate alt text #}

{# Start multi-site checkbox #}
{{ forms.lightswitchField({
    label: "Automatically use each site’s language (multi-site)",
    instructions: "When enabled, the plugin detects the language configured for each site and generates alt text in that language. You can manage sites and languages in <a href=\"" ~ cpUrl('settings/sites') ~ "\"><strong>Settings → Sites</strong></a>."|raw,
    id: 'autoUseSiteLanguage',
    name: 'autoUseSiteLanguage',
    on: settings.autoUseSiteLanguage
}) }}
{# End multi-site checkbox #}

{# Start language #}
{{ forms.selectField({
    label: "Language",
    options: languages,
    id: 'lang',
    name: 'lang',
    value: settings.lang ?? 'en',
    errors: settings.getErrors('lang')
}) }}
{# End language #}

{# Start Model type #}
{{ forms.selectField({
    label: "Model type",
    options: modelOptions,
    id: 'modelName',
    name: 'modelName',
    value: settings.modelName ?? 'describe-regular',
    errors: settings.getErrors('modelName')
}) }}
{# End Model type #}

{# Start Field for Alt Text #}
{% set volumes = craft.app.getVolumes().getAllVolumes() %}
{% set customFields = [] %}
{% set customField = {
    label: 'Alt (default)',
    value: 'alt',
    data: {
        'translation-method': 'site'
    }
} %}
{% set customFields = customFields|merge([customField]) %}
{% for volume in volumes %}
    {% set layout = volume.fieldLayout() %}
    {% for field in layout.getCustomFields() %}
        {% if field.className == "craft\\fields\\PlainText" %}
            {% set customField = {
                label: field.name,
                value: field.handle,
                data: {
                    'translation-method': field.translationMethod
                }
            } %}

            {% set customFields = customFields|merge([customField]) %}
        {% endif %}
    {% endfor %}
{% endfor %}

{{ forms.selectField({
    label: "Field for Alt Text",
    instructions: "You'll need to resync your assets after changing this setting.",
    options: customFields,
    id: 'customField',
    name: 'customField',
    value: settings.customField ?? 'alt',
    errors: settings.getErrors('customField')
}) }}
{# End Field for Alt Text #}

{# Start Field for Alt Text multi-site warning #}
<div data-alttextlab-customfield-warning="1"
     class="warning"
     style="margin-top:8px;">
    <p style="margin:0;">
        When “Automatically use each site’s language (multi-site)” is enabled, the plugin can only store different alt texts per site/language if the selected field is translatable per-site/per-language.
        For the default <code>alt</code> field, set it in <a href="{{ cpUrl('settings/assets') }}"><strong>Settings → Assets</strong></a> → your volume → Field layout; for custom fields, set “Translation Method” in <a href="{{ cpUrl('settings/fields') }}"><strong>Settings → Fields</strong></a>.
    </p>
</div>
{# End Field for Alt Text multi-site warning #}

{# Start public checkbox #}
{{ forms.lightswitchField({
    label: "This site is reachable over the public internet",
    instructions: "",
    id: 'isPublic',
    name: 'isPublic',
    on: settings.isPublic
}) }}
{# End public checkbox #}

{# Start disable volumes #}
{% set volumeOptions = [] %}
{% for volume in volumes %}
    {% set volumeOptions = volumeOptions|merge([{ label: volume.name, value: volume.uid }]) %}
{% endfor %}

{{ forms.checkboxSelectField({
    label: "Disable volumes",
    instructions: "Assets in these volumes will be excluded from alt text generation.",
    id: 'disabledVolumeUids',
    name: 'disabledVolumeUids',
    options: volumeOptions,
    values: settings.disabledVolumeUids ?? []
}) }}
{# End disable volumes #}
{% js %}
(() => {
  const init = () => {
    const langSelect = document.querySelector('select[name$="[lang]"]');
    const customFieldSelect = document.querySelector('select[name$="[customField]"]');
    const warning = document.querySelector('[data-alttextlab-customfield-warning]');
    const autoLangInput = document.querySelector('input[type="hidden"][name$="[autoUseSiteLanguage]"]');

    if (!langSelect || !customFieldSelect || !warning || !autoLangInput) {
      return false;
    }

    const lightswitch = autoLangInput.closest('.field')?.querySelector('.lightswitch');
    if (!lightswitch) {
      return false;
    }

    const isAutoOn = () => autoLangInput.value === '1';

    const apply = () => {
      const locked = isAutoOn();

      langSelect.disabled = false;
      langSelect.setAttribute('aria-disabled', locked ? 'true' : 'false');

      const lockTarget =
        langSelect.closest('.select') ||
        langSelect.closest('.input') ||
        langSelect.parentElement;

      if (lockTarget) {
        lockTarget.classList.toggle('alttextlab-select-locked', locked);
      }

      warning.hidden = !isAutoOn();
    };

    if (!lightswitch.dataset.alttextlabBound) {
      lightswitch.dataset.alttextlabBound = '1';
      lightswitch.addEventListener('click', () => setTimeout(apply, 0));
    }
    if (!customFieldSelect.dataset.alttextlabBound) {
      customFieldSelect.dataset.alttextlabBound = '1';
      customFieldSelect.addEventListener('change', apply);
    }

    apply();
    return true;
  };

  const timer = setInterval(() => {
    if (init()) {
      clearInterval(timer);
    }
  }, 200);

  init();
})();
{% endjs %}